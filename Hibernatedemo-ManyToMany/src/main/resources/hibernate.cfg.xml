<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration SYSTEM
"http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <property name="hbm2ddl.auto">update</property>
        <property name="dialect">org.hibernate.dialect.SQLServer2012Dialect</property>
        <property name="show_sql">true</property>

        <property name="connection.url">jdbc:sqlserver://localhost:1433;databaseName=HibernateManyToMany;encrypt=true;trustServerCertificate=true;</property>
        <property name="connection.username">sa</property>
        <property name="connection.password">admin123</property>
        <property name="connection.driver_class">com.microsoft.sqlserver.jdbc.SQLServerDriver</property>

        <mapping class="com.fe.pojo.Student" />
        <mapping class="com.fe.pojo.Book" />
    </session-factory>
</hibernate-configuration>
